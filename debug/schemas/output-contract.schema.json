{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://axis.dev/schemas/debug-output.v1.json",
  "title": "Axis Debug Output Contract",
  "description": "Defines the output files produced by the Axis Debug program generators.",
  "type": "object",
  "required": ["program", "outputs"],
  "properties": {
    "program": {
      "type": "string",
      "const": "debug",
      "description": "Program identifier"
    },
    "outputs": {
      "type": "array",
      "description": "Generated file manifest",
      "items": {
        "$ref": "#/definitions/GeneratedFile"
      },
      "minItems": 1
    }
  },
  "definitions": {
    "GeneratedFile": {
      "type": "object",
      "required": ["path", "content", "content_type", "program", "description"],
      "properties": {
        "path": {
          "type": "string",
          "description": "Output file path relative to project root",
          "enum": [".ai/debug-playbook.md", "incident-template.md", "tracing-rules.md", "root-cause-checklist.md"]
        },
        "content": {
          "type": "string",
          "minLength": 1,
          "description": "Generated file content — must be non-empty"
        },
        "content_type": {
          "type": "string",
          "enum": ["text/markdown", "text/plain", "application/json", "application/yaml", "text/css", "text/typescript", "text/tsx"],
          "description": "MIME type of the generated content"
        },
        "program": {
          "type": "string",
          "const": "debug",
          "description": "Owning program"
        },
        "description": {
          "type": "string",
          "minLength": 1,
          "description": "Human-readable description of this output"
        }
      },
      "additionalProperties": false
    }
  }
}

