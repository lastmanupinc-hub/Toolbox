{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://axis.dev/schemas/search-output.v1.json",
  "title": "Axis Search Output Contract",
  "description": "Defines the output files produced by the Axis Search program generators.",
  "type": "object",
  "required": ["program", "outputs"],
  "properties": {
    "program": {
      "type": "string",
      "const": "search",
      "description": "Program identifier"
    },
    "outputs": {
      "type": "array",
      "description": "Generated file manifest",
      "items": {
        "$ref": "#/definitions/GeneratedFile"
      },
      "minItems": 1
    }
  },
  "definitions": {
    "GeneratedFile": {
      "type": "object",
      "required": ["path", "content", "content_type", "program", "description"],
      "properties": {
        "path": {
          "type": "string",
          "description": "Output file path relative to project root",
          "enum": [".ai/context-map.json", ".ai/repo-profile.yaml", "architecture-summary.md", "dependency-hotspots.md"]
        },
        "content": {
          "type": "string",
          "minLength": 1,
          "description": "Generated file content — must be non-empty"
        },
        "content_type": {
          "type": "string",
          "enum": ["text/markdown", "text/plain", "application/json", "application/yaml", "text/css", "text/typescript", "text/tsx"],
          "description": "MIME type of the generated content"
        },
        "program": {
          "type": "string",
          "const": "search",
          "description": "Owning program"
        },
        "description": {
          "type": "string",
          "minLength": 1,
          "description": "Human-readable description of this output"
        }
      },
      "additionalProperties": false
    }
  }
}
