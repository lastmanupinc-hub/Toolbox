{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://axis.dev/schemas/context-map.v1.json",
  "title": "Axis Context Map",
  "description": "Structured project context graph produced by Axis Search from a snapshot. Consumed read-only by all Axis programs.",
  "type": "object",
  "required": [
    "version",
    "snapshot_id",
    "project_id",
    "generated_at",
    "project_identity",
    "structure",
    "detection",
    "dependency_graph",
    "entry_points"
  ],
  "properties": {
    "version": {
      "type": "string",
      "const": "1.0.0",
      "description": "Schema version for context-map.json"
    },
    "snapshot_id": {
      "type": "string",
      "format": "uuid",
      "description": "Snapshot that produced this context map"
    },
    "project_id": {
      "type": "string",
      "format": "uuid",
      "description": "Parent project"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 generation timestamp"
    },
    "project_identity": {
      "type": "object",
      "required": ["name", "type", "primary_language"],
      "properties": {
        "name": {
          "type": "string",
          "description": "Project name from manifest or inferred from repo"
        },
        "type": {
          "type": "string",
          "enum": [
            "saas_web_app",
            "api_service",
            "cli_tool",
            "library",
            "monorepo",
            "mobile_app",
            "static_site",
            "desktop_app",
            "data_pipeline",
            "ml_project",
            "unknown"
          ],
          "description": "Detected or declared project type"
        },
        "primary_language": {
          "type": "string",
          "description": "Dominant language by file count and LOC"
        },
        "description": {
          "type": "string",
          "description": "From README or manifest"
        },
        "repo_url": {
          "type": "string",
          "format": "uri",
          "description": "Source repository URL if available"
        }
      }
    },
    "structure": {
      "type": "object",
      "required": ["total_files", "total_directories", "total_loc", "file_tree_summary"],
      "properties": {
        "total_files": {
          "type": "integer",
          "minimum": 0
        },
        "total_directories": {
          "type": "integer",
          "minimum": 0
        },
        "total_loc": {
          "type": "integer",
          "minimum": 0,
          "description": "Total lines of code (excluding blanks and comments)"
        },
        "file_tree_summary": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["path", "type"],
            "properties": {
              "path": { "type": "string" },
              "type": {
                "type": "string",
                "enum": ["file", "directory"]
              },
              "language": { "type": "string" },
              "loc": { "type": "integer" },
              "role": {
                "type": "string",
                "enum": [
                  "source",
                  "test",
                  "config",
                  "documentation",
                  "build",
                  "asset",
                  "generated",
                  "unknown"
                ]
              }
            }
          },
          "description": "Annotated file tree with roles and languages"
        },
        "top_level_layout": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Top-level directories and their purposes"
        }
      }
    },
    "detection": {
      "type": "object",
      "required": ["languages", "frameworks"],
      "properties": {
        "languages": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "file_count", "loc_percent"],
            "properties": {
              "name": { "type": "string" },
              "file_count": { "type": "integer" },
              "loc_percent": { "type": "number", "minimum": 0, "maximum": 100 }
            }
          }
        },
        "frameworks": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "confidence"],
            "properties": {
              "name": { "type": "string" },
              "version": { "type": "string" },
              "confidence": {
                "type": "number",
                "minimum": 0,
                "maximum": 1,
                "description": "Detection confidence 0-1"
              },
              "evidence": {
                "type": "array",
                "items": { "type": "string" },
                "description": "Files or patterns that triggered detection"
              }
            }
          }
        },
        "build_tools": {
          "type": "array",
          "items": { "type": "string" }
        },
        "test_frameworks": {
          "type": "array",
          "items": { "type": "string" }
        },
        "package_managers": {
          "type": "array",
          "items": { "type": "string" }
        },
        "ci_platform": {
          "type": "string",
          "description": "Detected CI/CD platform"
        },
        "deployment_target": {
          "type": "string",
          "description": "Detected deployment target (vercel, aws, docker, etc.)"
        }
      }
    },
    "dependency_graph": {
      "type": "object",
      "required": ["external_dependencies", "internal_imports"],
      "properties": {
        "external_dependencies": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "version", "type"],
            "properties": {
              "name": { "type": "string" },
              "version": { "type": "string" },
              "type": {
                "type": "string",
                "enum": ["production", "development", "peer", "optional"]
              },
              "used_by": {
                "type": "array",
                "items": { "type": "string" },
                "description": "Files that import this dependency"
              }
            }
          }
        },
        "internal_imports": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["source", "target"],
            "properties": {
              "source": {
                "type": "string",
                "description": "Importing file path"
              },
              "target": {
                "type": "string",
                "description": "Imported file path"
              }
            }
          },
          "description": "File-to-file import edges"
        },
        "hotspots": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["path", "inbound_count", "outbound_count"],
            "properties": {
              "path": { "type": "string" },
              "inbound_count": {
                "type": "integer",
                "description": "How many files import this file"
              },
              "outbound_count": {
                "type": "integer",
                "description": "How many files this file imports"
              },
              "risk_score": {
                "type": "number",
                "minimum": 0,
                "maximum": 1,
                "description": "Change risk based on coupling"
              }
            }
          },
          "description": "High-coupling files that are dependency hotspots"
        }
      }
    },
    "entry_points": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "type"],
        "properties": {
          "path": { "type": "string" },
          "type": {
            "type": "string",
            "enum": [
              "app_entry",
              "api_route",
              "page_route",
              "cli_command",
              "worker",
              "test_suite",
              "build_config",
              "export"
            ]
          },
          "description": { "type": "string" }
        }
      },
      "description": "Discovered entry points into the codebase"
    },
    "routes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "source_file"],
        "properties": {
          "path": {
            "type": "string",
            "description": "URL route path"
          },
          "method": {
            "type": "string",
            "enum": ["GET", "POST", "PUT", "PATCH", "DELETE", "ALL"]
          },
          "source_file": { "type": "string" },
          "middleware": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      },
      "description": "Detected API and page routes"
    },
    "architecture_signals": {
      "type": "object",
      "properties": {
        "patterns_detected": {
          "type": "array",
          "items": { "type": "string" },
          "description": "e.g. MVC, CQRS, microservices, monolith, serverless"
        },
        "layer_boundaries": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "layer": { "type": "string" },
              "directories": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          },
          "description": "Detected architectural layers and their directory boundaries"
        },
        "separation_score": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "How well-separated are the architectural layers (0 = tangled, 1 = clean)"
        }
      }
    },
    "ai_context": {
      "type": "object",
      "description": "Pre-computed context summaries optimized for AI consumption",
      "properties": {
        "project_summary": {
          "type": "string",
          "description": "One-paragraph project summary for AI system prompts"
        },
        "key_abstractions": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Core domain concepts and their locations"
        },
        "conventions": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Detected coding conventions, naming patterns, file organization rules"
        },
        "warnings": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Risks, anti-patterns, or unusual structures detected"
        }
      }
    }
  }
}
