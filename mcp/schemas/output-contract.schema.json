{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://axis.dev/schemas/mcp-output.v1.json",
  "title": "Axis Mcp Output Contract",
  "description": "Defines the output files produced by the Axis Mcp program generators.",
  "type": "object",
  "required": ["program", "outputs"],
  "properties": {
    "program": {
      "type": "string",
      "const": "mcp",
      "description": "Program identifier"
    },
    "outputs": {
      "type": "array",
      "description": "Generated file manifest",
      "items": {
        "$ref": "#/definitions/GeneratedFile"
      },
      "minItems": 1
    }
  },
  "definitions": {
    "GeneratedFile": {
      "type": "object",
      "required": ["path", "content", "content_type", "program", "description"],
      "properties": {
        "path": {
          "type": "string",
          "description": "Output file path relative to project root",
          "enum": ["mcp-config.json","mcp-registry-metadata.json","protocol-spec.md","spec.types.ts","mcp/README.md","mcp/project-setup.md","mcp/build-artifacts.md","mcp/package-json.root.template.json","mcp/package-json.package.template.json","mcp/tsconfig.root.template.json","mcp/tsconfig.package.template.json","mcp/monorepo-structure.md","mcp/core-implementation-artifacts.md","mcp/testing-documentation-polish-artifacts.md","connector-map.yaml","capability-registry.json","server-manifest.yaml"]
        },
        "content": {
          "type": "string",
          "minLength": 1,
          "description": "Generated file content — must be non-empty"
        },
        "content_type": {
          "type": "string",
          "enum": ["text/markdown", "text/plain", "application/json", "application/yaml", "text/css", "text/typescript", "text/tsx"],
          "description": "MIME type of the generated content"
        },
        "program": {
          "type": "string",
          "const": "mcp",
          "description": "Owning program"
        },
        "description": {
          "type": "string",
          "minLength": 1,
          "description": "Human-readable description of this output"
        }
      },
      "additionalProperties": false
    }
  }
}

