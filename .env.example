# ─── Axis Toolbox API — Environment Variables ───────────────
# Copy this file to .env and customize as needed.

# HTTP listen port
# (default: 4000)
PORT=4000

# Runtime environment (development | production | test)
# (default: development)
NODE_ENV=development

# SQLite database file path
# (default: ./axis.db)
DATABASE_PATH=./axis.db

# Log verbosity (debug | info | warn | error)
# (default: info)
LOG_LEVEL=info

# Allowed CORS origin
# (default: *)
CORS_ORIGIN=*

# Rate limit sliding window in ms
# (default: 60000)
RATE_LIMIT_WINDOW_MS=60000

# Max requests per window (anonymous)
# (default: 60)
RATE_LIMIT_MAX_REQUESTS=60

# Max requests per window (authenticated)
# (default: 120)
RATE_LIMIT_MAX_AUTHENTICATED=120

# Graceful shutdown drain timeout in ms
# (default: 10000)
SHUTDOWN_TIMEOUT_MS=10000

# Per-request timeout in ms
# (default: 30000)
REQUEST_TIMEOUT_MS=30000

# Request body size limit in bytes (default: 50MB)
# (default: 52428800)
MAX_BODY_BYTES=52428800
