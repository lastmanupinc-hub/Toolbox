# ─── Axis' Iliad API — Environment Variables ───────────────
# Copy this file to .env and customize as needed.
#
# Platform notes:
#   Render  — set via render.yaml envVars or Render dashboard
#   Docker  — pass via docker-compose.yml environment block
#   Local   — copy to .env in project root

# ─── Server ─────────────────────────────────────────────────

# HTTP listen port
# (default: 4000)
PORT=4000

# Runtime environment (development | production | test)
# (default: development)
NODE_ENV=development

# Log verbosity (debug | info | warn | error)
# (default: info)
LOG_LEVEL=info

# ─── Database ───────────────────────────────────────────────

# SQLite database file path — MUST be on persistent storage in production
# Render: /data/axis.db (persistent disk)
# Docker: /data/axis.db (volume mount)
# (default: ./axis.db)
DATABASE_PATH=./axis.db

# ─── Security ───────────────────────────────────────────────

# Allowed CORS origin — set to your Cloudflare Pages domain in production
# Example: https://axis-iliad.jonathanarvay.com
# (default: *)
CORS_ORIGIN=*

# ─── Rate Limiting ──────────────────────────────────────────

# Rate limit sliding window in ms
# (default: 60000)
RATE_LIMIT_WINDOW_MS=60000

# Max requests per window (anonymous)
# (default: 60)
RATE_LIMIT_MAX_REQUESTS=60

# Max requests per window (authenticated)
# (default: 120)
RATE_LIMIT_MAX_AUTHENTICATED=120

# ─── Timeouts ───────────────────────────────────────────────

# Graceful shutdown drain timeout in ms
# (default: 10000)

# ─── Stripe (Payments) ──────────────────────────────────────

# Stripe secret key (sk_live_... or sk_test_...)
# STRIPE_SECRET_KEY=

# Stripe webhook signing secret (whsec_...)
# STRIPE_WEBHOOK_SECRET=

# Stripe Price IDs for each tier
# STRIPE_PRICE_ID_PAID=price_1TKO5IELErUdQ5HwgJdhG6b8
# STRIPE_PRICE_ID_SUITE=

# ─── Lemon Squeezy (Legacy — kept for webhook migration) ────

# LEMONSQUEEZY_API_KEY=
# LEMONSQUEEZY_STORE_ID=
# LEMONSQUEEZY_WEBHOOK_SECRET=
# LEMONSQUEEZY_VARIANT_ID_PAID=
# LEMONSQUEEZY_VARIANT_ID_SUITE=

# ─── Cloudflare Pages (Web App) ─────────────────────────────

# Set VITE_API_URL in Cloudflare Pages environment variables
# (NOT here — it's a Vite build-time variable, baked into the JS bundle)
#
# Cloudflare dashboard → Pages → axis-web → Settings → Environment variables:
#   VITE_API_URL = https://axis-api.onrender.com
#
# Custom domain: axis-iliad.jonathanarvay.com
# This tells the web app where to send API requests in production.
SHUTDOWN_TIMEOUT_MS=10000

# Per-request timeout in ms (0 = no limit)
# (default: 30000)
REQUEST_TIMEOUT_MS=30000

# Request body size limit in bytes (default: 50MB)
# (default: 52428800)
MAX_BODY_BYTES=52428800

# ─── GitHub OAuth (optional) ────────────────────────────────

# Create a GitHub OAuth App at https://github.com/settings/developers
# Set callback URL to: https://your-api.onrender.com/v1/auth/github/callback
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# GITHUB_CALLBACK_URL=https://your-api.onrender.com/v1/auth/github/callback
# AXIS_WEB_URL=https://axis.yourdomain.pages.dev
