# Axis' Iliad Content Posting Environment Variables
# Copy this file to .env and fill in your credentials

# Discord Webhook (easiest to get)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# Slack Webhook
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR_SLACK_WEBHOOK

# Dev.to API Key (for publishing articles)
DEVTO_API_KEY=your_devto_api_key_here

# Twitter/X API (requires developer account)
TWITTER_API_KEY=your_twitter_api_key
TWITTER_API_SECRET=your_twitter_api_secret
TWITTER_ACCESS_TOKEN=your_access_token
TWITTER_ACCESS_TOKEN_SECRET=your_access_token_secret

# Generic webhook (for custom integrations)
GENERIC_WEBHOOK_URL=https://your-custom-api.com/webhook